Тестирование
Создайте тестовый класс:

java
package ru.translate;

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

public class TextAnalyzerTest {
    
    @Test
    public void testSentenceCount() {
        TextAnalyzer analyzer = new TextAnalyzer();
        String text = "Первое предложение. Второе предложение! Третье?";
        AnalysisResult result = analyzer.analyze(text);
        assertEquals(3, result.getSentenceCount());
    }
    
    @Test
    public void testLongestWord() {
        TextAnalyzer analyzer = new TextAnalyzer();
        String text = "Короткое слово и длинноеслово";
        AnalysisResult result = analyzer.analyze(text);
        assertEquals("длинноеслово", result.getLongestWord());
    }
}
